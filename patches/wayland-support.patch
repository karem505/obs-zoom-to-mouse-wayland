+---
+-- Show/hide the GNOME top-bar zoom indicator (via the zoompointer@karem extension).
+-- No-op when not running under the Wayland D-Bus pointer setup.
+---@param active boolean True to show the indicator, false to hide it
+function set_zoom_indicator(active)
+    if not (use_wayland_pointer and gio_conn ~= nil) then
+        return
+    end
+    local err = ffi.new("GError*[1]")
+    local res = gio_lib.g_dbus_connection_call_sync(
+        gio_conn,
+        "org.gnome.Shell.Extensions.ZoomPointer",
+        "/org/gnome/Shell/Extensions/ZoomPointer",
+        "org.gnome.Shell.Extensions.ZoomPointer",
+        active and "ZoomOn" or "ZoomOff",
+        nil, nil, 0, 250, nil, err)
+    if res ~= nil then
+        glib_lib.g_variant_unref(res)
+    elseif err[0] ~= nil then
+        glib_lib.g_error_free(err[0])
+    end
+end
